import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from statsmodels.tsa.arima.model import ARIMA
from sklearn.linear_model import LinearRegression
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error
data = pd.read_csv("your_dataset.csv")

data['Date'] = pd.to_datetime(data['Date'], format='%m-%d-%Y')
data.set_index('Date', inplace=True)

ts_data = data['Production']

train_size = int(len(ts_data) * 0.8)
train, test = ts_data[:train_size], ts_data[train_size:]

def create_features(series):
    df = pd.DataFrame(series)
    df['lag1'] = df['Production'].shift(1)
    df = df.dropna()
    return df

train_df = create_features(train)
test_df = create_features(test)

lr_model = LinearRegression()
lr_model.fit(train_df[['lag1']], train_df['Production'])
lr_pred = lr_model.predict(test_df[['lag1']])

rf_model = RandomForestRegressor(n_estimators=100)
rf_model.fit(train_df[['lag1']], train_df['Production'])
rf_pred = rf_model.predict(test_df[['lag1']])

arima_model = ARIMA(train, order=(1,1,1))
arima_fit = arima_model.fit()
arima_pred = arima_fit.forecast(steps=len(test))

lr_mse = mean_squared_error(test_df['Production'], lr_pred)
rf_mse = mean_squared_error(test_df['Production'], rf_pred)
arima_mse = mean_squared_error(test, arima_pred)

print("Linear Regression MSE:", lr_mse)
print("Random Forest MSE:", rf_mse)
print("ARIMA MSE:", arima_mse)

plt.figure()
plt.plot(test.index, test, label='Actual')
plt.plot(test_df.index, lr_pred, label='Linear Regression')
plt.plot(test_df.index, rf_pred, label='Random Forest')
plt.plot(test.index, arima_pred, label='ARIMA')
plt.title("Model Comparison for Time Series")
plt.xlabel("Date")
plt.ylabel("Production")
plt.legend()

plt.show()
