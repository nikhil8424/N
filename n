# Import required libraries
import pandas as pd
import numpy as np
import nltk
import re

# Read dataset
data = pd.read_csv(
    'https://raw.githubusercontent.com/mohitgupta-omg/Kaggle-SMS-Spam-Collection-Dataset-/master/spam.csv',
    encoding='latin-1'
)

# Drop unnecessary columns and rename
data.drop(['Unnamed: 2', 'Unnamed: 3', 'Unnamed: 4'], axis=1, inplace=True)
data.columns = ['label', 'text']

# Check the dataset
print(data.head())

# Check for missing values
print(data.isna().sum())

# Check shape
print("Dataset shape:", data.shape)

# Check target balance
data['label'].value_counts(normalize=True).plot.bar()

# Download nltk resources
nltk.download('all')

from nltk.corpus import stopwords
from nltk.stem import WordNetLemmatizer

lemmatizer = WordNetLemmatizer()
corpus = []

# Cleaning, tokenizing, removing stopwords, lemmatizing
for i in range(len(data['text'])):
    r = re.sub('[^a-zA-Z]', ' ', data['text'][i])  # remove special chars
    r = r.lower()  # convert to lowercase
    r = r.split()  # tokenize
    r = [word for word in r if word not in stopwords.words('english')]  # remove stopwords
    r = [lemmatizer.lemmatize(word) for word in r]  # lemmatize
    r = ' '.join(r)
    corpus.append(r)

# Assign cleaned text back to dataframe
data['text'] = corpus
print(data.head())

from sklearn.model_selection import train_test_split

X = data['text']
y = data['label']

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.33, random_state=123
)

print('Training Data :', X_train.shape)
print('Testing Data : ', X_test.shape)

from sklearn.feature_extraction.text import CountVectorizer

cv = CountVectorizer()
X_train_cv = cv.fit_transform(X_train)
X_test_cv = cv.transform(X_test)

print("Train matrix shape:", X_train_cv.shape)

from sklearn.linear_model import LogisticRegression
from sklearn import metrics

lr = LogisticRegression()
lr.fit(X_train_cv, y_train)

# Predictions
predictions = lr.predict(X_test_cv)
print(predictions)

df_cm = pd.DataFrame(
    metrics.confusion_matrix(y_test, predictions),
    index=['ham', 'spam'],
    columns=['ham', 'spam']
)

print(df_cm)

