from nltk.sentiment import SentimentIntensityAnalyzer
import nltk

from wordcloud import WordCloud

# Download NLTK data (run once)
nltk.download('stopwords')
nltk.download('vader_lexicon')

# ================================
# PART 1: LDA TOPIC MODELING
# ================================

# Set your directory containing .txt files
folder_path = "your_text_files_folder"

# Read all text files
documents = []
for file in os.listdir(folder_path):
    if file.endswith(".txt"):
        with open(os.path.join(folder_path, file), 'r', encoding='utf-8', errors='ignore') as f:
            documents.append(f.read())

# Preprocessing using CountVectorizer
vectorizer = CountVectorizer(
    stop_words='english',
    lowercase=True
)

dtm = vectorizer.fit_transform(documents)

# Apply LDA
k = 3  # number of topics
lda = LatentDirichletAllocation(n_components=k, random_state=42)
lda.fit(dtm)

# Display topics
words = vectorizer.get_feature_names_out()

print("\n===== TOPICS =====")
for i, topic in enumerate(lda.components_):
    print(f"\nTopic {i+1}:")
    print([words[i] for i in topic.argsort()[-10:]])

# Topic distribution per document
doc_topics = lda.transform(dtm)

print("\n===== DOCUMENT TOPIC DISTRIBUTION =====")
print(doc_topics)


